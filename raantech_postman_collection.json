{
  "info": {
    "name": "Raantech Dashboard API - Users",
    "description": "API collection for user management including soft delete, restore, pagination, and searching.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Users (Paginated & Search)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=10&search=john&isDeleted=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "john" },
                { "key": "isDeleted", "value": "false" }
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n    \"success\": true,\n    \"statusCode\": 200,\n    \"message\": \"Users retrieved successfully\",\n    \"meta\": {\n        \"page\": 1,\n        \"limit\": 10,\n        \"total\": 5,\n        \"totalPage\": 1\n    },\n    \"data\": [\n        {\n            \"id\": \"647f1b2c...\",\n            \"name\": \"John Doe\",\n            \"email\": \"john@example.com\",\n            \"role\": \"ADMIN\",\n            \"status\": \"ACTIVE\",\n            \"isDeleted\": false,\n            \"createdAt\": \"2026-07-20T00:00:00Z\"\n        }\n    ]\n}"
            }
          ]
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Jane Smith\",\n    \"email\": \"jane@example.com\",\n    \"role\": \"STAFF\",\n    \"permissions\": [\"manage_products\"]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id"],
              "variable": [{ "key": "id", "value": "647f1b2c..." }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Jane Smith Updated\",\n    \"role\": \"ADMIN\",\n    \"status\": \"INACTIVE\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Soft Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id"],
              "variable": [{ "key": "id", "value": "647f1b2c..." }]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n    \"success\": true,\n    \"statusCode\": 200,\n    \"message\": \"User deleted successfully\",\n    \"data\": null\n}"
            }
          ]
        },
        {
          "name": "Restore User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id/restore",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id", "restore"],
              "variable": [{ "key": "id", "value": "647f1b2c..." }]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n    \"success\": true,\n    \"statusCode\": 200,\n    \"message\": \"User restored successfully\",\n    \"data\": {\n        \"id\": \"647f1b2c...\",\n        \"name\": \"Jane Smith\",\n        \"isDeleted\": false,\n        \"status\": \"ACTIVE\"\n    }\n}"
            }
          ]
        }
      ]
    }
  ]
}
