# Email Configuration
CONTACT_EMAIL_USER=your_email@gmail.com
CONTACT_EMAIL_APP_PASSWORD="your_app_password_here"

# Database Configuration
MONGODB_URI=mongodb://<username>:<password>@cluster0-shard-00-00.pw1gp.mongodb.net:27017,cluster0-shard-00-01.pw1gp.mongodb.net:27017,cluster0-shard-00-02.pw1gp.mongodb.net:27017/raantech_db?ssl=true&replicaSet=atlas-68qoe7-shard-0&authSource=admin&retryWrites=true&w=majority&appName=Cluster0

# JWT Configuration
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_COOKIE_MAX_AGE=604800
JWT_REFRESH_COOKIE_MAX_AGE=2592000

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"
